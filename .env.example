# Telegram 配置
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Docker 宿主机端口；应用容器内部固定监听 3000
PORT=3000

# 代理配置（可选）
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# 邮件配置（SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_auth_code
SMTP_FROM=工单系统 <your_email@qq.com>

# JWT 认证
JWT_SECRET=generate_a_random_secret_key_at_least_32_characters_long
JWT_EXPIRES_IN=24h
