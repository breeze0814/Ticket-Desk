# QQ 邮箱 SMTP 配置示例
# 将这些配置添加到你的 .env 文件中

# SMTP 邮件配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@qq.com
SMTP_PASS=breewsvvtilqbcai
SMTP_FROM=工单系统 <your_email@qq.com>

# JWT 认证配置（需要生成）
JWT_SECRET=请运行以下命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRES_IN=24h

# Telegram 配置
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
